{
  "name": "@zhangferry-dev/tokendash",
  "version": "1.7.4",
  "type": "module",
  "description": "Token Usage Analytics Dashboard",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "bin": {
    "tokendash": "bin/tokendash.js"
  },
  "files": [
    "dist",
    "bin",
    "resources"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.json && node esbuild.config.mjs",
    "build:swift": "cd TokenDashSwift && swift build -c release",
    "build:app": "npm run build && npm run build:swift && ./scripts/package-app.sh",
    "build:dmg": "npm run build:app && ./scripts/create-dmg.sh",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepack": "npm run build",
    "release:npm": "npm publish --access public --registry https://registry.npmjs.org",
    "deploy:check": "./scripts/deploy.sh --dry-run",
    "deploy": "./scripts/deploy.sh"
  },
  "dependencies": {
    "express": "^5.1.0",
    "open": "^10.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^4.1.4"
  }
}
